# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
# URL do frontend — usada nos redirects do Stripe Checkout (sucesso/cancelamento)
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string → URI
# Troca [YOUR-PASSWORD] pela senha do projeto
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key — NAO use a anon key!
SUPABASE_BUCKET=ticco-files

# ── Anthropic (Claude claude-sonnet-4-5) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (Whisper — primario) ────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── OpenAI (Whisper — fallback) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp — Z-API ─────────────────────────────────────────────────────────
# Painel Z-API → sua instância → Configurações
ZAPI_INSTANCE_ID=seu-instance-id
ZAPI_TOKEN=seu-token
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_SECURITY_TOKEN=seu-security-token   # opcional, mas recomendado

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
# OBRIGATÓRIO em produção — sem ela o backend rejeita silenciosamente todo webhook.
# Pega em: Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs dos planos — Stripe Dashboard → Products → Prices → copie o "price_..."
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_COMPLETO=price_...

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-string-aleatoria-de-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Admin ─────────────────────────────────────────────────────────────────────
# Header X-Admin-Key protege /admin/* e /v1/auth/issue-token.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=troque-por-string-aleatoria

# ── Founder ───────────────────────────────────────────────────────────────────
FOUNDER_PHONE=+5516999999999

# ── ICP-Brasil / ClickSign ────────────────────────────────────────────────────
# Mude ICP_BRASIL_ENABLED para true quando quiser ativar assinatura real
ICP_BRASIL_ENABLED=false
CLICKSIGN_API_KEY=
CLICKSIGN_BASE_URL=https://app.clicksign.com/api/v1
CLICKSIGN_WEBHOOK_SECRET=

# ── Emails do produto ─────────────────────────────────────────────────────────
# Aparecem nas mensagens do bot, PDFs e comunicações automáticas
CONTACT_EMAIL=ola@useticco.com
FOUNDER_EMAIL=joao@useticco.com
NOREPLY_EMAIL=noreply@useticco.com
